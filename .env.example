# Django
DJANGO_SECRET_KEY=change-me-to-a-secure-random-string-minimum-50-chars
# Field encryption key — generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=generate-a-fernet-key-see-above
# âš  PRODUCTION: Set DEBUG=False and DEV_MODE=False before going live!
DEBUG=True
DEV_MODE=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DB_ENGINE=django.db.backends.postgresql
DB_NAME=overberg_adventures
DB_USER=oa_user
DB_PASSWORD=changeme_strong_password
DB_HOST=db
DB_PORT=5432

# Email (SendGrid)
SENDGRID_API_KEY=
DEFAULT_FROM_EMAIL=noreply@overstrandadventures.co.za

# Google Maps
GOOGLE_MAPS_API_KEY=

# ---------------------------------------------------------------------------
# Social Auth (django-allauth)
# ---------------------------------------------------------------------------
# Google OAuth2 credentials â€” get from Google Cloud Console
# https://console.cloud.google.com/apis/credentials
# Authorised redirect URI: https://yourdomain.com/accounts/google/login/callback/
GOOGLE_CLIENT_ID=
GOOGLE_SECRET=

# Social Auth (Facebook)
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# Web Push VAPID (generate with: python manage.py generate_vapid_keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_ADMIN_EMAIL=admin@overstrandadventures.co.za

# Payment Gateway
# Options: manual | payfast | peach | dev (dev only works when DEV_MODE=True)
PAYMENT_GATEWAY=manual

# Redis / Celery
REDIS_URL=redis://redis:6379/0
# Note: Celery workers need broker_connection_retry_on_startup=True in Django settings
# This is configured in overberg_adventures/settings.py

# Site
SITE_ID=1
